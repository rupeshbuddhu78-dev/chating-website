<h1>Dashboard</h1>
<div class="stat-grid">
  <div class="stat"><h4>Total Users</h4><b><%= stats.totalUsers %></b></div>
  <div class="stat"><h4>Premium</h4><b><%= stats.premiumUsers %></b></div>
  <div class="stat"><h4>Banned</h4><b><%= stats.bannedUsers %></b></div>
  <div class="stat"><h4>Online</h4><b><%= stats.onlineUsers %></b></div>
  <div class="stat"><h4>Payments</h4><b><%= stats.totalPayments %></b></div>
  <div class="stat"><h4>Revenue</h4><b>₹<%= stats.revenue %></b></div>
  <div class="stat"><h4>Reports Pending</h4><b><%= stats.reportsPending %></b></div>
</div>
