<section class="auth-wrap">
  <form class="auth-card" method="POST" action="/auth/signup">
    <h1>Create Account</h1>
    <% if (error) { %><div class="err"><%= error %></div><% } %>
    <label>Name <input type="text" name="name" required maxlength="60" /></label>
    <label>Email <input type="email" name="email" required autocomplete="email" /></label>
    <label>Password <input type="password" name="password" required minlength="6" autocomplete="new-password" /></label>
    <label>Gender
      <select name="gender">
        <option value="">—</option>
        <option>Male</option><option>Female</option><option>Other</option>
      </select>
    </label>
    <label>Country <input type="text" name="country" maxlength="60" /></label>
    <button type="submit" class="btn primary big">Sign Up</button>
    <a href="/auth/google" class="btn google">Continue with Google</a>
    <p class="alt">Already have an account? <a href="/auth/login">Login</a></p>
  </form>
</section>
